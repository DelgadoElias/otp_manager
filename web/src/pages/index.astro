---
const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TOTP Tester</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
      font-family: 'Segoe UI', system-ui, sans-serif;
      color: #e2e8f0;
      padding: 1rem;
    }

    .card {
      background: rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 20px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
    }

    h1 {
      font-size: 1.6rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 0.5rem;
      background: linear-gradient(90deg, #a78bfa, #60a5fa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .subtitle {
      text-align: center;
      font-size: 0.9rem;
      color: #94a3b8;
      margin-bottom: 2rem;
    }

    .step { display: none; }
    .step.active { display: block; }

    label {
      display: block;
      font-size: 0.85rem;
      color: #94a3b8;
      margin-bottom: 0.4rem;
      font-weight: 500;
    }

    input[type="email"],
    input[type="text"] {
      width: 100%;
      padding: 0.75rem 1rem;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 10px;
      color: #e2e8f0;
      font-size: 1rem;
      outline: none;
      transition: border-color 0.2s;
    }

    input[type="email"]:focus,
    input[type="text"]:focus {
      border-color: #a78bfa;
    }

    input[type="text"].token-input {
      text-align: center;
      font-size: 1.8rem;
      font-weight: 700;
      letter-spacing: 0.5rem;
      padding: 0.75rem;
    }

    button {
      width: 100%;
      margin-top: 1.25rem;
      padding: 0.85rem;
      border: none;
      border-radius: 10px;
      background: linear-gradient(90deg, #7c3aed, #2563eb);
      color: white;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
    }

    button:hover { opacity: 0.9; }
    button:active { transform: scale(0.98); }
    button:disabled { opacity: 0.5; cursor: not-allowed; }

    .qr-wrapper {
      display: flex;
      justify-content: center;
      margin: 1.5rem 0;
    }

    .qr-wrapper img {
      width: 200px;
      height: 200px;
      border-radius: 12px;
      border: 3px solid rgba(167, 139, 250, 0.4);
    }

    .qr-hint {
      text-align: center;
      font-size: 0.82rem;
      color: #64748b;
      margin-bottom: 1.5rem;
    }

    .secret-reveal {
      text-align: center;
      margin-top: 0.75rem;
    }

    .secret-reveal summary {
      font-size: 0.8rem;
      color: #7c3aed;
      cursor: pointer;
      list-style: none;
    }

    .secret-reveal summary:hover { text-decoration: underline; }

    .secret-code {
      margin-top: 0.5rem;
      font-family: monospace;
      font-size: 0.9rem;
      background: rgba(124, 58, 237, 0.15);
      border: 1px solid rgba(124, 58, 237, 0.3);
      border-radius: 8px;
      padding: 0.5rem 0.75rem;
      word-break: break-all;
      color: #c4b5fd;
    }

    .result {
      text-align: center;
      padding: 2rem 0 1rem;
    }

    .result-icon {
      font-size: 4rem;
      display: block;
      margin-bottom: 1rem;
    }

    .result-title {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .result-title.success { color: #4ade80; }
    .result-title.error   { color: #f87171; }

    .result-msg {
      font-size: 0.9rem;
      color: #94a3b8;
      margin-bottom: 1.5rem;
    }

    .btn-ghost {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.15);
      margin-top: 0;
    }

    .btn-ghost:hover { background: rgba(255,255,255,0.05); }

    .error-msg {
      margin-top: 0.75rem;
      padding: 0.6rem 0.9rem;
      background: rgba(248, 113, 113, 0.15);
      border: 1px solid rgba(248, 113, 113, 0.3);
      border-radius: 8px;
      font-size: 0.85rem;
      color: #fca5a5;
      display: none;
    }

    .spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      vertical-align: middle;
      margin-right: 6px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* API URL banner */
    .api-banner {
      background: rgba(234, 179, 8, 0.12);
      border: 1px solid rgba(234, 179, 8, 0.3);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      font-size: 0.82rem;
      color: #fde68a;
      margin-bottom: 1.5rem;
      display: none;
    }

    .api-banner input {
      margin-top: 0.5rem;
      font-size: 0.82rem;
      padding: 0.5rem 0.75rem;
    }

    .api-banner button {
      margin-top: 0.5rem;
      padding: 0.4rem;
      font-size: 0.82rem;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>TOTP Tester</h1>
    <p class="subtitle">Test your MFA setup end-to-end</p>

    <div class="api-banner" id="apiBanner">
      ⚠️ No API URL configured. Enter your Railway deployment URL:
      <input type="text" id="apiUrlInput" placeholder="https://your-app.railway.app" />
      <button onclick="saveApiUrl()">Save & Continue</button>
    </div>

    <!-- Step 1: Email -->
    <div class="step active" id="step1">
      <label for="emailInput">Email address</label>
      <input type="email" id="emailInput" placeholder="user@example.com" />
      <div class="error-msg" id="emailError"></div>
      <button id="btnGenerate" onclick="generateSecret()">Continue</button>
    </div>

    <!-- Step 2: QR + Validate -->
    <div class="step" id="step2">
      <p class="qr-hint">Scan this QR code with Google Authenticator, Authy, or any TOTP app.</p>
      <div class="qr-wrapper">
        <img id="qrImage" src="" alt="QR Code" />
      </div>
      <details class="secret-reveal">
        <summary>Can't scan? Use the secret key</summary>
        <div class="secret-code" id="secretCode"></div>
      </details>

      <div style="margin-top: 1.5rem;">
        <label for="tokenInput">Enter the 6-digit code from your app</label>
        <input
          type="text"
          id="tokenInput"
          class="token-input"
          placeholder="000000"
          maxlength="6"
          inputmode="numeric"
          pattern="[0-9]*"
        />
      </div>
      <div class="error-msg" id="tokenError"></div>
      <button id="btnValidate" onclick="validateToken()">Verify</button>
      <button class="btn-ghost" onclick="resetToStep1()" style="margin-top: 0.5rem;">← Try another email</button>
    </div>

    <!-- Step 3: Result -->
    <div class="step" id="step3">
      <div class="result">
        <span class="result-icon" id="resultIcon"></span>
        <div class="result-title" id="resultTitle"></div>
        <p class="result-msg" id="resultMsg"></p>
      </div>
      <button onclick="goToValidate()">Try again</button>
      <button class="btn-ghost" onclick="resetToStep1()" style="margin-top: 0.5rem;">← Start over</button>
    </div>
  </div>

  <script define:vars={{ apiUrl }}>
    let API_BASE = apiUrl || localStorage.getItem('otp_api_url') || '';
    let currentEmail = '';
    let currentSecret = '';

    function init() {
      if (!API_BASE) {
        document.getElementById('apiBanner').style.display = 'block';
      }
    }

    function saveApiUrl() {
      const val = document.getElementById('apiUrlInput').value.trim().replace(/\/$/, '');
      if (!val) return;
      localStorage.setItem('otp_api_url', val);
      API_BASE = val;
      document.getElementById('apiBanner').style.display = 'none';
    }

    function showStep(n) {
      document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
      document.getElementById('step' + n).classList.add('active');
    }

    function showError(elId, msg) {
      const el = document.getElementById(elId);
      el.textContent = msg;
      el.style.display = 'block';
    }

    function clearError(elId) {
      const el = document.getElementById(elId);
      el.textContent = '';
      el.style.display = 'none';
    }

    function setLoading(btnId, loading) {
      const btn = document.getElementById(btnId);
      if (loading) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span>Loading...';
      } else {
        btn.disabled = false;
      }
    }

    async function generateSecret() {
      clearError('emailError');
      const email = document.getElementById('emailInput').value.trim();
      if (!email || !email.includes('@')) {
        showError('emailError', 'Enter a valid email address.');
        return;
      }
      if (!API_BASE) {
        showError('emailError', 'Set your API URL first.');
        return;
      }

      setLoading('btnGenerate', true);
      try {
        const res = await fetch(`${API_BASE}/otp/generate-secret?username=${encodeURIComponent(email)}`, {
          method: 'POST'
        });
        const data = await res.json();

        if (!res.ok) {
          showError('emailError', data.error || 'Something went wrong.');
          return;
        }

        currentEmail = email;
        currentSecret = data.secret;
        document.getElementById('qrImage').src = data.qrCode;
        document.getElementById('secretCode').textContent = data.secret;
        document.getElementById('tokenInput').value = '';
        showStep(2);
      } catch (e) {
        showError('emailError', 'Could not reach the API. Check the URL and CORS settings.');
      } finally {
        document.getElementById('btnGenerate').disabled = false;
        document.getElementById('btnGenerate').textContent = 'Continue';
      }
    }

    async function validateToken() {
      clearError('tokenError');
      const token = document.getElementById('tokenInput').value.trim();
      if (token.length !== 6 || !/^\d+$/.test(token)) {
        showError('tokenError', 'Enter a valid 6-digit code.');
        return;
      }

      setLoading('btnValidate', true);
      try {
        const res = await fetch(
          `${API_BASE}/otp/validate?username=${encodeURIComponent(currentEmail)}&otp=${token}`,
          { method: 'POST' }
        );
        const data = await res.json();

        if (data.valid) {
          document.getElementById('resultIcon').textContent = '✅';
          document.getElementById('resultTitle').className = 'result-title success';
          document.getElementById('resultTitle').textContent = 'Code accepted!';
          document.getElementById('resultMsg').textContent = 'Your TOTP setup is working correctly.';
        } else {
          document.getElementById('resultIcon').textContent = '❌';
          document.getElementById('resultTitle').className = 'result-title error';
          document.getElementById('resultTitle').textContent = 'Incorrect code';
          document.getElementById('resultMsg').textContent = 'The code is wrong or expired. Make sure your device time is synced.';
        }
        showStep(3);
      } catch (e) {
        showError('tokenError', 'Could not reach the API.');
      } finally {
        document.getElementById('btnValidate').disabled = false;
        document.getElementById('btnValidate').textContent = 'Verify';
      }
    }

    function goToValidate() {
      document.getElementById('tokenInput').value = '';
      clearError('tokenError');
      showStep(2);
    }

    function resetToStep1() {
      currentEmail = '';
      currentSecret = '';
      document.getElementById('emailInput').value = '';
      clearError('emailError');
      showStep(1);
    }

    // Allow Enter key on inputs
    document.addEventListener('DOMContentLoaded', () => {
      init();
      document.getElementById('emailInput').addEventListener('keydown', e => {
        if (e.key === 'Enter') generateSecret();
      });
      document.getElementById('tokenInput').addEventListener('keydown', e => {
        if (e.key === 'Enter') validateToken();
      });
      // Only allow digits in token input
      document.getElementById('tokenInput').addEventListener('input', e => {
        e.target.value = e.target.value.replace(/\D/g, '');
      });
    });
  </script>
</body>
</html>
