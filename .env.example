# PostgreSQL connection
# For Railway: use the JDBC URL from the PostgreSQL plugin variables
# Format: jdbc:postgresql://<PGHOST>:<PGPORT>/<PGDATABASE>
DATABASE_URL=jdbc:postgresql://localhost:5432/otp_manager
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# App config
OTP_APP_NAME=MyApp
OTP_SECRET_EXPIRATION_DAYS=30

# Rate limiting (per IP — restrictive defaults for free tier)
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_HOUR=20